# Copy this file to .env and adjust as needed. Never commit the real .env.

# Path to the devices YAML file (see devices.yaml.example).
MIKROTIK_DEVICES_FILE=devices.yaml

# Read-only by default. Set to true only when you intend to use write tools
# (set_identity, enable/disable_interface, set_wifi_ssid, set_client_bandwidth,
# add_static_dhcp_lease, remove_simple_queue). See README.md "Security model".
MIKROTIK_ALLOW_WRITE=false

# Log level for the server process (stderr; stdout is reserved for the MCP
# stdio transport). Invalid values fall back to INFO with a warning instead
# of crashing at startup.
MIKROTIK_LOG_LEVEL=INFO

# Fallback connect timeout (seconds) for devices that don't set their own
# `timeout` in devices.yaml. Default: 10.
MIKROTIK_TIMEOUT=10

# --- Production features (v0.5) - see README.md "Production features" -----

# Append-only JSON-lines audit log for every guarded write call (preview,
# applied, or error). If unset, audit events go to the regular stderr log
# (INFO level) instead of a file. Never contains a device password.
# MIKROTIK_AUDIT_LOG=/var/log/mcp-mikrotik/audit.jsonl

# Extra retry attempts for READ operations (path/ping/traceroute) on a
# transient network error, with a short backoff (0.5s, then 1s). Writes
# never retry, regardless of this value. Default: 2.
MIKROTIK_READ_RETRIES=2

# Circuit breaker: consecutive connection failures to one device before its
# circuit opens and further calls to it fail fast (no connection attempted)
# for MIKROTIK_BREAKER_COOLDOWN seconds. Default: 3.
MIKROTIK_BREAKER_THRESHOLD=3

# Circuit breaker cooldown (seconds) before a trial reconnect is allowed
# again once the circuit is open. Default: 30.
MIKROTIK_BREAKER_COOLDOWN=30
