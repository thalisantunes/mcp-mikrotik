# Copy this file to .env and adjust as needed. Never commit the real .env.

# Path to the devices YAML file (see devices.yaml.example).
MIKROTIK_DEVICES_FILE=devices.yaml

# Read-only by default. Set to true only when you intend to use write tools
# (currently just set_identity). See README.md "Security model".
MIKROTIK_ALLOW_WRITE=false

# Log level for the server process (stderr; stdout is reserved for the MCP
# stdio transport).
MIKROTIK_LOG_LEVEL=INFO
